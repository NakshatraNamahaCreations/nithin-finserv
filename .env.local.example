# Copy this file to .env.local and fill in your Gmail credentials.
# .env.local is gitignored — never commit real credentials.

# ──────────────────────────────────────────────────────────────
# Gmail SMTP setup
# ──────────────────────────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google account:
#    https://myaccount.google.com/security
#
# 2. Create an App Password (a 16-character code Gmail generates
#    for non-browser apps). You CANNOT use your normal Gmail
#    password — Google blocks SMTP login with it:
#    https://myaccount.google.com/apppasswords
#    → App: "Mail", Device: "Other (Nithin Finserv site)"
#    Copy the 16-char password Google gives you (e.g. "abcd efgh ijkl mnop")
#    and paste it into SMTP_PASS below (spaces optional).
#
# 3. Paste your Gmail address into SMTP_USER below.
# ──────────────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=asnithin30@gmail.com
SMTP_PASS=gkhcrpdnglshjlhz

# ──────────────────────────────────────────────────────────────
# Email addresses
# ──────────────────────────────────────────────────────────────
# CONTACT_FROM = display name + sender shown in the "From" header.
# Gmail will rewrite this to your authenticated address, but the
# display name ("Nithin Finserv") will still show in the inbox.
CONTACT_FROM="Nithin Finserv <asnithin30@gmail.com>"

# CONTACT_TO = where consultation requests are delivered. Usually
# the same Gmail you authenticated with — that way submissions
# land in your own inbox.
CONTACT_TO=asnithin30@gmail.com
